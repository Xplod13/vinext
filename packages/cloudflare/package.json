{
  "name": "@vinext/cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare adapters for vinext (KV data cache, edge CDN cache, and Images-backed image optimization).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/vinext.git",
    "directory": "packages/cloudflare"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./cache/*": {
      "types": "./dist/cache/*.d.ts",
      "import": "./dist/cache/*.js"
    },
    "./image/*": {
      "types": "./dist/image/*.d.ts",
      "import": "./dist/image/*.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "prepack": "vp run build",
    "dev": "vp pack --watch"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vinext": "workspace:*",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "vinext": ">=0.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
